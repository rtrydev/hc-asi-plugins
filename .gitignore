# macOS / editor cruft
.DS_Store
*.swp
*~

# Python caches (the x87 translator toolchain)
__pycache__/
*.py[cod]

# Compiled objects / build intermediates
*.o
*.obj
*.tmp
*.orig
*.bak

# Built binaries — regenerated by `make` / build.ps1 / translate.py, never tracked
dist/
*.asi
*.dll
*.exe
*.x87
*.leaf.txt

# Release archive — uploaded to GitHub Releases, not tracked
hc-asi-plugins.zip
